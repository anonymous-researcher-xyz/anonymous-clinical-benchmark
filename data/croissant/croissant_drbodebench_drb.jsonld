{
  "@context": {
    "@language": "pt",
    "@vocab": "https://schema.org/",
    "citeAs": "cr:citeAs",
    "column": "cr:column",
    "conformsTo": "dct:conformsTo",
    "cr": "http://mlcommons.org/croissant/",
    "rai": "http://mlcommons.org/croissant/RAI/",
    "data": {
      "@id": "cr:data",
      "@type": "@json"
    },
    "dataType": {
      "@id": "cr:dataType",
      "@type": "@vocab"
    },
    "dct": "http://purl.org/dc/terms/",
    "examples": {
      "@id": "cr:examples",
      "@type": "@json"
    },
    "extract": "cr:extract",
    "field": "cr:field",
    "fileProperty": "cr:fileProperty",
    "fileObject": "cr:fileObject",
    "fileSet": "cr:fileSet",
    "format": "cr:format",
    "includes": "cr:includes",
    "isLiveDataset": "cr:isLiveDataset",
    "jsonPath": "cr:jsonPath",
    "key": "cr:key",
    "md5": "cr:md5",
    "parentField": "cr:parentField",
    "path": "cr:path",
    "recordSet": "cr:recordSet",
    "references": "cr:references",
    "regex": "cr:regex",
    "repeated": "cr:repeated",
    "replace": "cr:replace",
    "sc": "https://schema.org/",
    "separator": "cr:separator",
    "source": "cr:source",
    "subField": "cr:subField",
    "transform": "cr:transform",
    "wd": "https://www.wikidata.org/wiki/"
  },
  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "DrBodeBench-DRB",
  "license": "Apache-2.0",
  "version": "1.0",
  "description": "Multiple-choice medical examination dataset in Portuguese. Contains clinical case scenarios with multiple-choice questions primarily from Brazilian medical licensing exams. Each question presents a clinical situation and requires selecting the most appropriate medical conduct or diagnosis. This dataset was processed and standardized from the original corpus. This file contains only Croissant metadata; the preprocessed data is NOT distributed. Users must obtain the original version from Hugging Face and execute the provided preprocessing script.",
  "url": "https://github.com/lisaterumi/clinicalbenchpt",
  "citation": "Please cite the original authors' work when using this dataset (https://ieeexplore.ieee.org/abstract/document/11058810). When using the processed version, please also cite our work.",
  "keywords": [
    "multiple choice",
    "medical examination",
    "clinical reasoning",
    "medical education",
    "Portuguese",
    "NLP",
    "INEP",
    "medical licensing"
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "source-repository",
      "name": "source-repository",
      "description": "Original dataset repository on Hugging Face. Data must be downloaded from this source and processed using the provided scripts.",
      "contentUrl": "https://huggingface.co/datasets/recogna-nlp/drbodebench",
      "encodingFormat": "application/json",
      "sha256": "dummy"
    },
    {
      "@type": "cr:FileObject",
      "@id": "train.jsonl",
      "name": "train.jsonl",
      "description": "Processed training set (generated after running preprocessing scripts). Contains 1282 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/drbodebench/train.jsonl",
      "sha256": "69040dcc6d8e968464d2c5230a06a812b0566128c4c16f7b101b9fa9e345d1af"
    },
    {
      "@type": "cr:FileObject",
      "@id": "dev.jsonl",
      "name": "dev.jsonl",
      "description": "Processed development set. Contains 158 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/drbodebench/train.jsonl",
      "sha256": "45277a8d8508a489a7db5c843ddd27a2ebb89ab40c1794169dafa68d91edeeb0"
    },
    {
      "@type": "cr:FileObject",
      "@id": "test.jsonl",
      "name": "test.jsonl",
      "description": "Processed test set. Contains 158 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/drbodebench/train.jsonl",
      "sha256": "4aec636efdc7fd76a91f284e0acae379b0d87c198cb6a2d8c8db80ddeb0cb518"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "multiple-choice-examples",
      "name": "multiple-choice-examples",
      "description": "Multiple-choice clinical case questions with alternatives and answers",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/id",
          "name": "id",
          "description": "Unique identifier for the example",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "id"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "id"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "id"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/origem",
          "name": "origem",
          "description": "Source of the question (e.g., INEP for Brazilian medical licensing exams)",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "origem"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "origem"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "origem"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/prova",
          "name": "prova",
          "description": "Year of the examination",
          "dataType": "sc:Integer",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "prova"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "prova"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "prova"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/numero",
          "name": "numero",
          "description": "Question number in the original examination",
          "dataType": "sc:Integer",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "numero"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "numero"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "numero"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/enunciado",
          "name": "enunciado",
          "description": "Clinical case scenario and question statement",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "enunciado"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "enunciado"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "enunciado"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/alternativas",
          "name": "alternativas",
          "description": "Dictionary containing answer options (typically A, B, C, D) with their corresponding text",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "task"}, 
                "transform": {
                "replace": "*/Please refer to the 'alternativas' field in the original dataset."
            } },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "task"} , 
                "transform": {
                "replace": "*/Please refer to the 'alternativas' field in the original dataset."
            } },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "task"} , 
              "transform": {
              "replace": "*/Please refer to the 'alternativas' field in the original dataset."
            } }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/resposta",
          "name": "resposta",
          "description": "Correct answer option (e.g., A, B, C, or D)",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "resposta"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "resposta"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "resposta"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/contains_img",
          "name": "contains_img",
          "description": "Boolean indicating whether the question contains an image",
          "dataType": "sc:Boolean",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "contains_img"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "contains_img"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "contains_img"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/img_path",
          "name": "img_path",
          "description": "Path to the image file if contains_img is true, null otherwise",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "img_path"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "img_path"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "img_path"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/img_description",
          "name": "img_description",
          "description": "Description of the image content if contains_img is true, null otherwise",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "img_description"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "img_description"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "img_description"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "multiple-choice-examples/task",
          "name": "task",
          "description": "Task type identifier (always 'multiple_choice' for this dataset)",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "task"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "task"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "task"} }
          ]
         }
      ]
    }
  ]
}