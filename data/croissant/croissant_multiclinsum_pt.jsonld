{
  "@context": {
    "@language": "pt",
    "@vocab": "https://schema.org/",
    "citeAs": "cr:citeAs",
    "column": "cr:column",
    "conformsTo": "dct:conformsTo",
    "cr": "http://mlcommons.org/croissant/",
    "rai": "http://mlcommons.org/croissant/RAI/",
    "data": {
      "@id": "cr:data",
      "@type": "@json"
    },
    "dataType": {
      "@id": "cr:dataType",
      "@type": "@vocab"
    },
    "dct": "http://purl.org/dc/terms/",
    "examples": {
      "@id": "cr:examples",
      "@type": "@json"
    },
    "extract": "cr:extract",
    "field": "cr:field",
    "fileProperty": "cr:fileProperty",
    "fileObject": "cr:fileObject",
    "fileSet": "cr:fileSet",
    "format": "cr:format",
    "includes": "cr:includes",
    "isLiveDataset": "cr:isLiveDataset",
    "jsonPath": "cr:jsonPath",
    "key": "cr:key",
    "md5": "cr:md5",
    "parentField": "cr:parentField",
    "path": "cr:path",
    "recordSet": "cr:recordSet",
    "references": "cr:references",
    "regex": "cr:regex",
    "repeated": "cr:repeated",
    "replace": "cr:replace",
    "sc": "https://schema.org/",
    "separator": "cr:separator",
    "source": "cr:source",
    "subField": "cr:subField",
    "transform": "cr:transform",
    "wd": "https://www.wikidata.org/wiki/"
  },
  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "MultiClinSum-PT",
  "license": "CC-BY-4.0",
  "version": "1.0",
  "description": "Clinical text summarization dataset in Portuguese. Contains detailed clinical case reports paired with concise summaries. Each example includes a comprehensive clinical narrative (patient history, symptoms, examinations, diagnoses, treatments, and outcomes) along with a gold-standard summary highlighting the key clinical information. This dataset was processed and standardized from the original corpus. This file contains only Croissant metadata; the preprocessed data is NOT distributed. Users must obtain the original version from Zenodo and execute the provided preprocessing script.",
  "url": "https://github.com/lisaterumi/clinicalbenchpt",
  "citation": "Please cite the original authors' work when using this dataset (https://ceur-ws.org/Vol-4038/paper_2.pdf). When using the processed version, please also cite our work.",
  "keywords": [
    "summarization",
    "clinical cases",
    "medical",
    "healthcare",
    "Portuguese",
    "NLP",
    "text generation"
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "source-repository",
      "name": "source-repository",
      "description": "Original dataset repository on Zenodo. Data must be downloaded from this source and processed using the provided scripts.",
      "contentUrl": "https://zenodo.org/records/15459174",
      "encodingFormat": "application/zip",
      "sha256": "dummy"
    },
    {
      "@type": "cr:FileObject",
      "@id": "train.jsonl",
      "name": "train.jsonl",
      "description": "Processed training set (generated after running preprocessing scripts). Contains 473 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/multiclinsum_pt/train.jsonl",
      "sha256": "f6c099296c1821bb4d8a72aa084ae8d041705a59c9e44b54b88be63a5b3edf88"
    },
    {
      "@type": "cr:FileObject",
      "@id": "dev.jsonl",
      "name": "dev.jsonl",
      "description": "Processed development set. Contains 59 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/multiclinsum_pt/train.jsonl",
      "sha256": "2f2b868657fc1d31d7e205bd90132db5c9e990c338b2462efd533103b3df8a0a"
    },
    {
      "@type": "cr:FileObject",
      "@id": "test.jsonl",
      "name": "test.jsonl",
      "description": "Processed test set. Contains 60 examples.",
      "encodingFormat": "application/jsonlines",
      "contentUrl": "../data/multiclinsum_pt/train.jsonl",
      "sha256": "87a1c6448371bc84687b168e6f9e22c5bcc58f61021d998fbe0c7135375ca983"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "summarization-examples",
      "name": "summarization-examples",
      "description": "Clinical case reports with reference summaries",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "summarization-examples/id",
          "name": "id",
          "description": "Unique identifier for the clinical case",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "id"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "id"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "id"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "summarization-examples/text",
          "name": "text",
          "description": "Full clinical case report text in Portuguese. Contains comprehensive information including patient demographics, medical history, presenting symptoms, physical examination findings, laboratory results, imaging studies, diagnoses, treatments, and clinical outcomes",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "text"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "text"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "text"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "summarization-examples/summary",
          "name": "summary",
          "description": "Gold-standard reference summary of the clinical case. Provides a concise overview highlighting the most relevant clinical information, including key findings, diagnosis, and treatment outcome",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "summary"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "summary"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "summary"} }
          ]
        },
        {
          "@type": "cr:Field",
          "@id": "summarization-examples/task",
          "name": "task",
          "description": "Task type identifier (always 'summarization' for this dataset)",
          "dataType": "sc:Text",
          "source": [
            { "fileObject": { "@id": "train.jsonl"}, "extract": {"column": "task"} },
            { "fileObject": { "@id": "dev.jsonl" }, "extract": {"column": "task"} },
            { "fileObject": { "@id": "test.jsonl" }, "extract": {"column": "task"} }
          ]
         }
      ]
    }
  ]
}